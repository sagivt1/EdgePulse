# ----------------------------------------------------------------------
# C++ Build Artifacts
# ----------------------------------------------------------------------
# Compiled Object files
*.o
*.obj
*.slo
*.lo

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.a
*.lib
*.lai
*.la

# Executables and Debug symbols
*.exe
*.out
*.app
*.pdb
*.idb
*.dSYM/

# Precompiled Headers
*.gch
*.pch

# ----------------------------------------------------------------------
# CMake
# ----------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt
compile_commands.json

# Build directories (common patterns)
build/
build_*/
cmake-build-*/
bin/
lib/

# ----------------------------------------------------------------------
# Conan (Dependency Manager)
# ----------------------------------------------------------------------
# Temporary files generated by Conan
conanbuildinfo.cmake
conanbuildinfo.txt
conaninfo.txt
graph_info.json
conan_toolchain.cmake
conan_provider.cmake
conan_*.cmake
conanrunenv*
conanbuildenv*

# ----------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------
# Local overrides for docker-compose (often contains secrets/local paths)
docker-compose.override.yml

